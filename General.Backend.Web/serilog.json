{
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console", "Serilog.Expressions" ],
    "MinimumLevel": {
      "Default": "Verbose", //Verbose、Debug、Information、Warning
      "Override": {
        "Microsoft": "Information",
        "System": "Information",
        "Volo.Abp": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "restrictedToMinimumLevel": "Verbose"
        }
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "WriteTo": [
              {
                "Name": "File",
                "Args": {
                  "path": "logs/log_web_.log", //格式log_20250308.log
                  "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{SourceContext}] {Message}{NewLine}{Exception}",
                  "rollingInterval": "Day", // 日志按天保存Infinite、Year、Month、Day、Hour、Minute、RollingFile（弃用）
                  "retainedFileCountLimit": 100, //默认31，最大保存文件数
                  "restrictedToMinimumLevel": "Verbose", //Verbose、Debug、Information、Warning
                  "rollOnFileSizeLimit": true, // 默认false, 开启滚动策略
                  "fileSizeLimitBytes": 524288000 //默认1G，最大单个文件字节，100M 524288000byte=500M，rollOnFileSizeLimit如果为false，则到达单个文件大小时，在下一个滚动点之前将不会再写入日志
                }
              }
            ]
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}